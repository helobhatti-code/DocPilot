# ===========================================================================
# GPMS — Environment configuration template
# Copy to .env and fill in. NEVER commit the real .env to source control.
# ===========================================================================

# --- Application -----------------------------------------------------------
NODE_ENV=development        # development | production | test
PORT=3000                   # API port (web/nginx is on 8080 via docker compose)
API_PREFIX=api/v1           # All routes are mounted under this prefix
CORS_ORIGIN=*               # Comma-separated allow-list, or `*`

# --- Database --------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gpms
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gpms?schema=public

# --- JWT (REQUIRED in production — generate with `openssl rand -hex 64`) ----
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Redis (Bull queues) ---------------------------------------------------
# Optional. If set, REDIS_URL takes precedence over REDIS_HOST/PORT/PASSWORD.
# Managed providers (Render, Upstash, Heroku) usually expose this form.
# Use rediss:// for TLS-protected endpoints.
# REDIS_URL=redis://default:password@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Redis is optional at boot — the API will start without it (background jobs
# and email delivery degrade gracefully; in-app notifications still work).

# --- File storage ----------------------------------------------------------
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:3000
MAX_FILE_SIZE_BYTES=2097152   # 2 MB

# --- SMTP / email ----------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@gpms.local

# --- Seed data (first-run only) -------------------------------------------
SEED_TENANT_NAME=UpTown Technical Service LLC
SEED_ADMIN_EMAIL=admin@gpms.com
SEED_ADMIN_PASSWORD=123@gpms

# --- Backups ---------------------------------------------------------------
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
PG_CONTAINER=gpms-postgres

# --- Web (Vite, baked at build time) --------------------------------------
VITE_API_URL=/api/v1
